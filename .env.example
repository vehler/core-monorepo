# Copy to .env.local (or per-app .env.local files) and fill in values.
# Each app validates its own env — see apps/*/src/env.* files.

# --- apps/api ---
API_PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000

# --- @core/db (SQLite for dev; swap to Postgres in packages/db/src/client.ts) ---
DATABASE_URL=file:./dev.db

# --- @core/auth (BetterAuth) ---
# Generate a real secret for production: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-in-production-at-least-32-chars
BETTER_AUTH_URL=http://localhost:4000
# COOKIE_DOMAIN=.yourdomain.com      # set in staging/prod for cross-subdomain cookies
# EXTRA_CORS_ORIGINS=                # comma-separated additional trusted origins

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
